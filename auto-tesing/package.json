{
  "name": "user-auth-api-tests",
  "version": "1.0.0",
  "description": "Automated tests for the user authentication API",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:profile": "jest tests/profile-api.test.js tests/extended-profile-tests.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose"
  },
  "keywords": [
    "authentication",
    "api",
    "testing",
    "profile",
    "avatar"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "devDependencies": {
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.3"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.1",
    "global-agent": "^4.1.2",
    "helmet": "^7.0.0",
    "https-proxy-agent": "^7.0.6",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "validator": "^13.9.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}